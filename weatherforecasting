function HourlyForecast({ city, unit }) {
  const ul = unitLabel(unit);
  const now = new Date();
  const hours = Array.from({ length: 12 }, (_, i) => {
    const h = (now.getHours() + i * 2) % 24;
    const variation = Math.round(Math.sin(i * 0.6) * 3);
    const tc = city.tempC + variation;
    const label = h === 0 ? "12am" : h < 12 ? `${h}am` : h === 12 ? "12pm" : `${h - 12}pm`;
    return { label, icon: HOURLY_ICONS[i], temp: convertTemp(tc, unit) };
  });
  return (
    <div style={S.card}>
      <div style={S.sectionTitle}>Hourly Forecast</div>
      <div style={S.hourlyRow}>
        {hours.map((h, i) => (
          <div key={i} style={S.hourlyCard}>
            <div style={S.hcTime}>{h.label}</div>
            <div style={S.hcIcon}>{h.icon}</div>
            <div style={S.hcTemp}>{h.temp}{ul}</div>
          </div>
        ))}
      </div>
    </div>
  );
}

function FiveDayForecast({ city, unit }) {
  const ul = unitLabel(unit);
  const today = new Date().getDay();
  const days = Array.from({ length: 5 }, (_, i) => ({
    day: DAYS[(today + i + 1) % 7],
    icon: FORECAST_ICONS[i],
    high: convertTemp(city.tempC + Math.floor(Math.random() * 4 - 1), unit),
    low:  convertTemp(city.tempC - Math.floor(Math.random() * 7 + 4), unit),
  }));
  return (
    <div style={S.card}>
      <div style={S.sectionTitle}>5-Day Forecast</div>
      <div style={S.forecastGrid}>
        {days.map((d, i) => (
          <div key={i} style={S.fcCard}>
            <div style={S.fcDay}>{d.day}</div>
            <div style={S.fcIcon}>{d.icon}</div>
            <div style={S.fcHigh}>{d.high}{ul}</div>
            <div style={S.fcLow}>{d.low}{ul}</div>
          </div>
        ))}
      </div>
    </div>
  );
}

function TemperatureConverter({ defaultC }) {
  const [input, setInput] = useState(String(defaultC));
  useEffect(() => { setInput(String(defaultC)); }, [defaultC]);

  const c = parseFloat(input);
  const valid = !isNaN(c);
  const fVal = valid ? cToF(c).toFixed(1) : "—";
  const kVal = valid ? cToK(c).toFixed(2) : "—";
  const cVal = valid ? c.toFixed(1) : "—";

  return (
    <div style={S.card}>
      <div style={S.sectionTitle}>Temperature Converter</div>
      <div style={S.convRow}>
        <div style={S.convInputWrap}>
          <input
            type="number"
            style={S.convInput}
            value={input}
            onChange={e => setInput(e.target.value)}
            step="0.5"
          />
          <span style={S.convLabel}>°C</span>
        </div>
        <div style={S.convArrow}>→</div>
        <span style={{ fontFamily: "'DM Mono'", fontSize: 13, color: "#546e7a" }}>all units</span>
      </div>
      <div style={S.convResults}>
        <div style={S.convItem("#4fc3f7")}>
          <div style={S.convResLabel}>Celsius</div>
          <div style={S.convResVal("#4fc3f7")}>{cVal}°C</div>
        </div>
        <div style={S.convItem("#ffd54f")}>
          <div style={S.convResLabel}>Fahrenheit</div>
          <div style={S.convResVal("#ffd54f")}>{fVal}°F</div>
        </div>
        <div style={S.convItem("#a5d6a7")}>
          <div style={S.convResLabel}>Kelvin</div>
          <div style={S.convResVal("#a5d6a7")}>{kVal} K</div>
        </div>
      </div>
      <div style={S.formulaBox}>
        <div style={S.formulaText}>
          <span style={{ color: "#ffd54f" }}>°F</span> = (°C × 9/5) + 32
          &nbsp;&nbsp;&nbsp;
          <span style={{ color: "#a5d6a7" }}>K</span> = °C + 273.15
          &nbsp;&nbsp;&nbsp;
          <span style={{ color: "#4fc3f7" }}>°C</span> = (°F − 32) × 5/9
        </div>
      </div>
    </div>
  );
}

function CityComparison({ unit }) {
  const ul = unitLabel(unit);
  const cities = Object.values(WEATHER_DB).slice(0, 8);
  return (
    <div style={S.card}>
      <div style={S.sectionTitle}>Global Temperature Snapshot</div>
      <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
        {cities.map(c => {
          const t = convertTemp(c.tempC, unit);
          const pct = Math.max(0, Math.min(100, ((c.tempC + 10) / 55) * 100));
          return (
            <div key={c.name} style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <span style={{ width: 90, fontSize: 12, color: "#90a4ae", flexShrink: 0 }}>{c.name}</span>
              <span style={{ fontSize: 14 }}>{c.icon}</span>
              <div style={{
                flex: 1, height: 8, background: "rgba(255,255,255,0.07)",
                borderRadius: 8, overflow: "hidden",
              }}>
                <div style={{
                  width: `${pct}%`, height: "100%", borderRadius: 8,
                  background: c.tempC >= 35 ? "#ef5350" : c.tempC >= 25 ? "#ffa726" : c.tempC >= 15 ? "#4fc3f7" : "#81c784",
                  transition: "width 0.6s ease",
                }} />
              </div>
              <span style={{ fontFamily: "'Syne', sans-serif", fontSize: 14, fontWeight: 700, color: "#e3f2fd", width: 52, textAlign: "right" }}>
                {t}{ul}
              </span>
            </div>
          );
        })}
      </div>
      <div style={{ marginTop: 16, display: "flex", gap: 16, flexWrap: "wrap" }}>
        {[["#ef5350","Hot (35°C+)"],["#ffa726","Warm (25-34°C)"],["#4fc3f7","Cool (15-24°C)"],["#81c784","Cold (<15°C)"]].map(([c,l]) => (
          <div key={l} style={{ display: "flex", alignItems: "center", gap: 6 }}>
            <div style={{ width: 10, height: 10, borderRadius: "50%", background: c }} />
            <span style={{ fontSize: 11, color: "#546e7a" }}>{l}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

// ─── Main App ─────────────────────────────────────────────────────────────────
export default function WeatherApp() {
  const [unit, setUnit] = useState("C");
  const [query, setQuery] = useState("chennai");
  const [city, setCity] = useState(WEATHER_DB["chennai"]);
  const [notFound, setNotFound] = useState(false);

  const handleSearch = useCallback(() => {
    const q = query.trim().toLowerCase();
    const match = WEATHER_DB[q] ||
      Object.values(WEATHER_DB).find(c => c.name.toLowerCase() === q || c.name.toLowerCase().startsWith(q));
    if (match) { setCity(match); setNotFound(false); }
    else setNotFound(true);
  }, [query]);

  const SUGGESTIONS = ["Chennai","London","Tokyo","Dubai","Sydney","Paris","Moscow","Berlin"];

  return (
    <>
      <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
      <style>{`
        * { box-sizing: border-box; margin: 0; padding: 0; }
        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
        ::-webkit-scrollbar { height: 4px; } 
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(79,195,247,0.3); border-radius: 4px; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        .fade-up { animation: fadeUp 0.5s ease both; }
        .hover-card:hover { border-color: rgba(79,195,247,0.35) !important; transform: translateY(-1px); transition: all 0.2s; }
      `}</style>
      <div style={S.root}>
        <div style={S.bgGlow(city)} />
        <div style={S.stars} />
        <div style={S.wrapper}>

          {/* Header */}
          <header style={S.header}>
            <div style={S.logo}>SKY<span style={S.logoSpan}>CAST</span></div>
            <UnitToggle unit={unit} setUnit={setUnit} />
          </header>

          {/* Search */}
          <SearchBar query={query} setQuery={setQuery} onSearch={handleSearch} />

          {notFound ? (
            <div style={S.notFound}>
              <div style={{ fontSize: 40, marginBottom: 12 }}>🔍</div>
              <div>City not found</div>
              <div style={{ fontSize: 14, marginTop: 8, marginBottom: 20 }}>Try one of these:</div>
              <div style={S.citySuggestions}>
                {SUGGESTIONS.map(s => (
                  <span key={s} style={S.suggTag} onClick={() => { setQuery(s.toLowerCase()); setNotFound(false); const m=WEATHER_DB[s.toLowerCase()]; if(m) setCity(m); }}>
                    {s}
                  </span>
                ))}
              </div>
            </div>
          ) : city ? (
            <div className="fade-up">
              <MainCard city={city} unit={unit} />
              <HourlyForecast city={city} unit={unit} />
              <FiveDayForecast city={city} unit={unit} />
              <TemperatureConverter defaultC={city.tempC} />
              <CityComparison unit={unit} />
            </div>
          ) : null}

        </div>
      </div>
    </>
  );
}
