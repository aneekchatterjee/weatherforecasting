// ─── Conversion helpers ───────────────────────────────────────────────────────
const cToF = (c) => +(c * 9 / 5 + 32).toFixed(1);
const cToK = (c) => +(c + 273.15).toFixed(2);

function convertTemp(c, unit) {
  if (unit === "F") return Math.round(cToF(c));
  if (unit === "K") return Math.round(cToK(c));
  return Math.round(c);
}
function unitLabel(unit) { return unit === "K" ? "K" : `°${unit}`; }

